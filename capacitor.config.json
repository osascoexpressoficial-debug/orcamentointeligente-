{
  "appId": "br.com.osascoexpress.app",
  "appName": "Osasco Express",
  "webDir": "src",
  "server": {
    "androidScheme": "https"
  },
  "plugins": {
    "SplashScreen": {
      "launchShowDuration": 2000,
      "backgroundColor": "#ea1d2c",
      "showSpinner": false
    },
    "StatusBar": {
      "style": "Default",
      "backgroundColor": "#ea1d2c"
    }
  },
  "ios": {
    "contentInset": "always"
  },
  "android": {
    "allowMixedContent": true
  }
}
