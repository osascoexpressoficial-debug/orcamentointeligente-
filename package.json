{
  "name": "osasco-express-app",
  "version": "1.0.0",
  "description": "Osasco Express — Sistema de Gestão Logística",
  "private": true,
  "scripts": {
    "start": "npx serve . -p 3000",
    "build": "echo 'Build: copie a pasta inteira para o servidor'",
    "cap:init": "npx cap init 'Osasco Express' 'br.com.osascoexpress.app' --web-dir src",
    "cap:add:ios": "npx cap add ios",
    "cap:add:android": "npx cap add android",
    "cap:sync": "npx cap sync",
    "cap:open:ios": "npx cap open ios",
    "cap:open:android": "npx cap open android"
  },
  "dependencies": {
    "@capacitor/core": "^5.0.0"
  },
  "devDependencies": {
    "@capacitor/cli": "^5.0.0",
    "@capacitor/ios": "^5.0.0",
    "@capacitor/android": "^5.0.0",
    "serve": "^14.0.0"
  }
}
